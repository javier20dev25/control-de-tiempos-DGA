rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is the Master Admin
    function isMasterAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'sleytherjavier2025@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role == 'admin'
      );
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if isMasterAdmin();
    }

    match /records/{recordId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      
      // Officials can only update/delete if they created it OR are admins
      allow update, delete: if isMasterAdmin() || 
        (request.auth.token.email == resource.data.createdBy);
    }

    match /shifts/{shiftId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      
      // Only the owner of the shift or admin can end it
      allow update: if isMasterAdmin() || 
        (request.auth.token.email == resource.data.userEmail);
      
      allow delete: if isMasterAdmin();
    }
  }
}
